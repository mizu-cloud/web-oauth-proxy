{
  "name": "web-oauth-proxy",
  "version": "0.1.0",
  "description": "Host-based OIDC reverse proxy with web admin UI",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop web-oauth-proxy",
    "restart:pm2": "pm2 restart web-oauth-proxy",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "openid-client": "^5.7.1",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "supertest": "^7.1.0"
  }
}
